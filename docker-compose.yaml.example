# ============================================================
# Auto-Multiple-Choice — docker-compose pour Mac Apple Silicon
# ============================================================
# Prérequis : XQuartz installé et configuré (voir README)
# Usage     : ./launch.sh
# ============================================================

services:
  amc:
    build:
      context: .
      dockerfile: Dockerfile
    image: amc-nqcm:latest

    # Force arm64 natif (pas d'émulation x86 lente)
    platform: linux/arm64

    # ── Affichage X11 via XQuartz ──────────────────────────
    environment:
      - DISPLAY=host.docker.internal:0
      - LANG=fr_FR.UTF-8
      - LC_ALL=fr_FR.UTF-8
      # Chemin des projets AMC par défaut
      - AMC_PROJECTS_DIR=/amc/projets

    # ── Volumes ────────────────────────────────────────────
    volumes:
      # Classe LaTeX personnalisée nQCM (lecture seule)
      - nQcm:/nqcm:ro

      # Dossier SCAN (lecture/écriture — AMC y écrit ses résultats)
      - scan:/amc/scan

      # Dossier CONTROLES (accès complet)
      - controles:/amc/controles

      # Données persistantes AMC (projets, configuration)
      - amc-data:/root/.AMC.d

    # ── Accès réseau au host (pour X11 TCP) ───────────────
    extra_hosts:
      - "host.docker.internal:host-gateway"

    # Permet d'éviter certains problèmes de rendu GTK/Cairo
    shm_size: '256mb'

    # Redémarre jamais automatiquement (c'est une appli GUI)
    restart: "no"

    # Profil de sécurité relâché pour X11
    security_opt:
      - seccomp:unconfined

# ── Volumes nommés ─────────────────────────────────────────
volumes:
  amc-data:
    driver: local
    # Les projets AMC sont persistés entre les sessions
