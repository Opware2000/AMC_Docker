# ============================================================
# Auto-Multiple-Choice — docker-compose pour Mac Apple Silicon
# ============================================================
# Prérequis : aucun (mode VNC — pas besoin de XQuartz)
# Usage     : Copiez ce fichier en docker-compose.yml
#             Adaptez les chemins des volumes ci-dessous
#             puis lancez : ./launch.sh
# ============================================================

services:
  amc:
    build:
      context: .
      dockerfile: Dockerfile
    image: amc-nqcm:latest

    # Force arm64 natif (pas d'émulation x86 lente)
    platform: linux/arm64

    # ── Variables d'environnement ──────────────────────────
    environment:
      - LANG=fr_FR.UTF-8
      - LC_ALL=fr_FR.UTF-8
      - VNC_GEOMETRY=1440x900    # Résolution VNC (ex: 1920x1200)

    # ── Port noVNC (navigateur) ────────────────────────────
    ports:
      - "6080:6080"

    # ── Volumes — ADAPTEZ CES CHEMINS ─────────────────────
    volumes:
      # Classe LaTeX personnalisée nQCM (lecture seule)
      - /chemin/vers/nQcm:/nqcm:ro

      # Dossier SCAN (lecture/écriture — AMC y écrit ses résultats)
      - /chemin/vers/SCAN:/amc/scan

      # Dossier CONTROLES contenant vos projets AMC (accès complet)
      - /chemin/vers/CONTROLES:/amc/controles

      # Données persistantes AMC (configuration, préférences)
      - amc-data:/root/.AMC.d

    # Permet d'éviter certains problèmes de rendu GTK/Cairo
    shm_size: '256mb'

    # ── Limites de ressources ──────────────────────────────
    deploy:
      resources:
        limits:
          cpus: '4'       # 4 cœurs max (ajustez selon votre Mac)
          memory: 2G      # 2 Go max (LaTeX + scans)
        reservations:
          cpus: '1'
          memory: 512M

    # Redémarre jamais automatiquement (c'est une appli GUI)
    restart: "no"

    # Profil de sécurité relâché pour X11
    security_opt:
      - seccomp:unconfined

# ── Volumes nommés ─────────────────────────────────────────
volumes:
  amc-data:
    driver: local
    # Les projets AMC sont persistés entre les sessions
