# Configuration pour le conteneur AMC
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# Mot de passe VNC (obligatoire pour la connexion)
# Par défaut: monpasswordsecret
VNC_PASSWORD=monpasswordsecret

# Variables d'environnement supplémentaires si besoin
# DISPLAY=:0
# LC_ALL=fr_FR.UTF-8
# LANG=fr_FR.UTF-8
# LANGUAGE=fr_FR.UTF-8